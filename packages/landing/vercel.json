{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/download",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(iPhone|iPad|iPod).*"
        }
      ],
      "destination": "https://apps.apple.com/us/app/good-fights/id6757172609",
      "permanent": false
    },
    {
      "source": "/download",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*Android.*"
        }
      ],
      "destination": "https://play.google.com/store/apps/details?id=com.fightcrewapp.mobile",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/verify-email", "destination": "/verify-email.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/delete-account", "destination": "/delete-account.html" },
    { "source": "/download", "destination": "/download.html" }
  ]
}
